        self.target = target
        self.thread_count = min(threads, 400)
        self.total_requests = total_req
        self._builder = RequestBuilder()

    def _worker(self):
        global _REQUESTS_SENT, _REQUESTS_FAILED, _RUNNING, _ACTIVE_THREADS

        with _LOCK:
            _ACTIVE_THREADS += 1

        while _RUNNING:
            with _LOCK:
                if _TOTAL_REQUESTS > 0 and _REQUESTS_SENT >= _TOTAL_REQUESTS:
                    _RUNNING = False
                    break

            request_data, used_path = self._builder.build(self.target)
            success, latency = SocketSender.send(
                self.target.host, self.target.port, self.target.ssl, request_data
            )

            with _LOCK:
                if success:
                    _REQUESTS_SENT += 1
                    _LATENCY_HISTORY.append(latency)
                else:
                    _REQUESTS_FAILED += 1
                    _REQUESTS_SENT += 1

        with _LOCK:
            _ACTIVE_THREADS -= 1

    def _stats_display(self):
        global _REQUESTS_SENT, _REQUESTS_FAILED, _RUNNING, _START_TIME

        while _RUNNING:
            time.sleep(0.5)

