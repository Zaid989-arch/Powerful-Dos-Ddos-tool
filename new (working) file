# PROGRESS BAR
# ──────────────────────────────────────────
class ProgressBar:
    @staticmethod
    def render(current, total, width=30):
        if total <= 0:
            return ""
        pct = min(100, (current / total) * 100)
        filled = int((pct / 100) * width)
        bar = "█" * filled + "░" * (width - filled)
        return f"[{C(bar)}] {GB(f'{pct:.0f}%')}"

