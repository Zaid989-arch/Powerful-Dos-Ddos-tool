class RequestBuilder:
    METHODS = ["GET", "GET", "GET", "GET", "POST", "HEAD"]
    REFERERS = [
        "https://www.google.com/search?q=",
        "https://www.facebook.com/",
        "https://t.co/",
        "https://www.reddit.com/r/",
        "https://www.bing.com/search?q=",
        "https://duckduckgo.com/?q=",
        "https://www.instagram.com/",
        "https://www.youtube.com/watch?v=",
        "https://www.linkedin.com/feed/",
        "",
        "",
    ]

    PATHS = [
        "/", "/index.html", "/index.php", "/index.htm",
        "/home", "/about", "/contact", "/services", "/products",
        "/login", "/admin", "/dashboard", "/profile", "/settings",
        "/wp-admin/", "/wp-login.php", "/wp-content/", "/wp-includes/",
        "/api/", "/api/v1/", "/api/status", "/api/health", "/api/users",
        "/api/data", "/api/config", "/api/auth/login",
        "/assets/js/app.js", "/assets/css/style.css",
        "/favicon.ico", "/robots.txt", "/sitemap.xml",
        "/.env", "/config.php", "/phpinfo.php",
        "/server-status", "/test.php", "/info.php",
        "/search", "/register", "/signup", "/forgot-password",
        "/blog", "/news", "/category/", "/tag/",
        "/download", "/uploads/", "/images/",
    ]

    def __init__(self):
        self._ua_pool = UserAgentPool()
        self._path_index = 0
        self._path_lock = threading.Lock()

    def _random_ip(self):
        return f"{random.randint(1,255)}.{random.randint(1,255)}.{random.randint(1,255)}.{random.randint(1,255)}"

    def _random_path(self):
        with self._path_lock:
            path = random.choice(self.PATHS)
            if random.random() < 0.3:
                # Use a regular static path with random param
                path = random.choice(self.PATHS)
                # Sometimes add a random numeric suffix
                base = path.rstrip("/")
                if random.random() < 0.4:
                    path = f"{base}?_{random.randint(100000,999999)}={random.randint(1,999)}"
            return path

    def build(self, target):
        method = random.choice(self.METHODS)
        path = self._random_path()
        ua = self._ua_pool.get()
        referer = random.choice(self.REFERERS)
        xff = self._random_ip()

        headers = [
            f"{method} {path} HTTP/1.1",
            f"Host: {target.host}",
            f"User-Agent: {ua}",
            "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
            "Accept-Language: en-US,en;q=0.9",
            "Accept-Encoding: gzip, deflate",
        ]

        if referer:
            headers.append(f"Referer: {referer}")

        headers.append(f"X-Forwarded-For: {xff}")
        headers.append(f"X-Real-IP: {xff}")
        headers.append("Connection: keep-alive")
        headers.append("Upgrade-Insecure-Requests: 1")
        headers.append("Sec-Fetch-Dest: document")
        headers.append("Sec-Fetch-Mode: navigate")
        headers.append("Sec-Fetch-Site: none")
        headers.append("Sec-Fetch-User: ?1")
        headers.append("Cache-Control: no-cache")
        headers.append("Pragma: no-cache")

        if method == "POST":
            headers.append("Content-Type: application/x-www-form-urlencoded")
            body = f"_={int(time.time())}&r={random.randint(1,999999)}"
            headers.append(f"Content-Length: {len(body)}")
            headers.append("")
            headers.append(body)
        else:
            headers.append("")

        return "\r\n".join(headers).encode(), path

