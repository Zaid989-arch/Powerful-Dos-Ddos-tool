# SOCKET SENDER — Termux Optimized
# ──────────────────────────────────────────
class SocketSender:
    _pools = {}
    _pool_lock = threading.Lock()
    _POOL_SIZE = 2
    _CONNECT_TIMEOUT = 5
    _SEND_TIMEOUT = 3
    _RECV_TIMEOUT = 2

    @classmethod
    def _pool_key(cls, host, port, ssl_flag):
        return f"{host}:{port}:{ssl_flag}"

    @classmethod
    def _create_socket(cls, host, port, ssl_enabled):
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(cls._CONNECT_TIMEOUT)
            sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)

            if ssl_enabled:
                ctx = ssl.create_default_context()
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
                ctx.minimum_version = ssl.TLSVersion.TLSv1_2
                sock = ctx.wrap_socket(sock, server_hostname=host)

            sock.connect((host, port))
            sock.settimeout(cls._SEND_TIMEOUT)
            return sock
        except Exception:
            try:
                sock.close()
            except Exception:
                pass
            return None

    @classmethod
    def _get_from_pool(cls, host, port, ssl_enabled):
        key = cls._pool_key(host, port, ssl_enabled)
        with cls._pool_lock:
            pool = cls._pools.get(key, [])
            while pool:
                sock = pool.pop()
                try:
                    sock.settimeout(0.1)
                    sock.send(b"")
                    sock.settimeout(cls._SEND_TIMEOUT)
                    return sock
                except Exception:
                    try:
                        sock.close()
                    except Exception:
                        pass
            return cls._create_socket(host, port, ssl_enabled)

    @classmethod
    def _return_to_pool(cls, host, port, ssl_enabled, sock):
        key = cls._pool_key(host, port, ssl_enabled)
        with cls._pool_lock:
            pool = cls._pools.setdefault(key, [])
            if len(pool) < cls._POOL_SIZE:
                pool.append(sock)
            else:
                try:
                    sock.close()
                except Exception:
                    pass

    @classmethod
    def send(cls, host, port, ssl_enabled, data):
        start = time.perf_counter()
        sock = cls._get_from_pool(host, port, ssl_enabled)
        if not sock:
            return False, 0.0

        try:
            sock.sendall(data)
            try:
                sock.settimeout(cls._RECV_TIMEOUT)
                sock.recv(1024)
            except socket.timeout:
                pass
            except Exception:
                pass

            latency = (time.perf_counter() - start) * 1000
            cls._return_to_pool(host, port, ssl_enabled, sock)
            return True, latency

        except Exception:
            try:
                sock.close()
            except Exception:
                pass
            return False, (time.perf_counter() - start) * 1000

    @classmethod
    def cleanup(cls):
        with cls._pool_lock:
            for key, pool in cls._pools.items():
                for sock in pool:
                    try:
                        sock.close()
                    except Exception:
                        pass
            cls._pools.clear()

