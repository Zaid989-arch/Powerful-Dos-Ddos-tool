def get_int_input(prompt, default, min_v, max_v):
    while True:
        try:
            raw = input(f"{C('[?]')} {Y(prompt)} {B('[')}{W(str(min_v) + '-' + str(max_v))}{B(', default: ')}{W(str(default))}{B(']')}: ")
            if not raw.strip():
                return default
            val = int(raw)
            if val < min_v:
                print(f"  {R('Minimum is ' + str(min_v) + ', using ' + str(min_v))}")
                return min_v
            if val > max_v:
                print(f"  {Y('Capping at ' + str(max_v))}")
                return max_v
            return val
        except ValueError:
            print(f"  {R('Invalid — enter a number.')}")

def get_target_input():
    print()
    raw = input(f"{C('[?]')} {Y('Enter target URL')} {B('(e.g., example.com:8080)')}: ")
