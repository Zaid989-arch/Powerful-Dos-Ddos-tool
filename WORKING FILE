def _c(text: str, color: str = "", style: str = "") -> str:
    """Apply color safely — degrades gracefully if colorama missing."""
    if _HAS_COLORS:
        return f"{style}{color}{text}{Style.RESET_ALL}"
    return text

def R(text): return _c(text, Fore.RED)
def G(text): return _c(text, Fore.GREEN)
def Y(text): return _c(text, Fore.YELLOW)
def C(text): return _c(text, Fore.CYAN)
def M(text): return _c(text, Fore.MAGENTA)
def W(text): return _c(text, Fore.WHITE)
def B(text): return _c(text, Fore.LIGHTBLACK_EX)
def RB(text): return _c(text, Fore.RED, Style.BRIGHT)
def GB(text): return _c(text, Fore.GREEN, Style.BRIGHT)
