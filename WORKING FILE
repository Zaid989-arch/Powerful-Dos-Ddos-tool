def get_int_input(prompt: str, default: int, min_v: int, max_v: int) -> int:
    """Get validated integer input from user."""
    while True:
        try:
            raw = input(f"{C('[?] ')} {Y(prompt)} {B('[')}{W(str(min_v) + '-' + str(max_v))}{B(', default: ')}{W(str(default))}{B(']')}: {W()}")
            if not raw.strip():
                return default
            val = int(raw)
            if val < min_v:
                print(f"  {R('Minimum is ' + str(min_v) + ', using ' + str(min_v))}")
                return min_v
            if val > max_v:
                print(f"  {Y('Capping at ' + str(max_v))}")
                return max_v
            return val
        except ValueError:
            print(f"  {R('Invalid — enter a number.')}")

def get_target_input() -> Optional[Target]:
    """Get and validate target URL from user."""
    print()
    raw = input(f"{C('[?]')} {Y('Enter target URL')} {B('(e.g., example.com:8080)')}: {W()}")
    target = Target.parse(raw)
    if not target:
        print(f"  {R('✗ Invalid target. Use format: domain.com, domain.com:8080, https://domain.com')}")
        return None

    print(f"  {G('✓ Target resolved:')} {W(target.host)}:{GB(str(target.port))} {'🔒 HTTPS' if target.ssl else '🔓 HTTP'}")
    return target

