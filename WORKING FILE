# SOCKET SENDER (optimized for Termux)
# ──────────────────────────────────────────
class SocketSender:
    """Manages raw socket connections — tuned for Android/Termux."""

    # Connection pools per destination
    _pools: Dict[str, List[socket.socket]] = {}
    _pool_lock = threading.Lock()
    _POOL_SIZE = 2  # Small pool to avoid socket exhaustion on Android
    _CONNECT_TIMEOUT = 5
    _SEND_TIMEOUT = 3
    _RECV_TIMEOUT = 2

    @classmethod
    def _pool_key(cls, host: str, port: int, ssl: bool) -> str:
        return f"{host}:{port}:{ssl}"

    @classmethod
    def _create_socket(cls, host: str, port: int, ssl_enabled: bool) -> Optional[socket.socket]:
        """Create a fresh socket connection."""
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(cls._CONNECT_TIMEOUT)
            # Disable Nagle's algorithm for lower latency
            sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)

            if ssl_enabled:
                ctx = ssl.create_default_context()
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
                # Use TLS 1.2/1.3 for speed and compatibility
                ctx.minimum_version = ssl.TLSVersion.TLSv1_2
                sock = ctx.wrap_socket(sock, server_hostname=host)

            sock.connect((host, port))
            sock.settimeout(cls._SEND_TIMEOUT)
            return sock
        except Exception:
            try:
                sock.close()
            except Exception:
                pass
            return None

    @classmethod
    def _get_from_pool(cls, host: str, port: int, ssl_enabled: bool) -> Optional[socket.socket]:
        """Get a socket from the pool or create a new one."""
        key = cls._pool_key(host, port, ssl_enabled)
        with cls._pool_lock:
            pool = cls._pools.get(key, [])
            while pool:
                sock = pool.pop()
                try:
                    # Quick connectivity test
                    sock.settimeout(0.1)
                    sock.send(b"")
                    sock.settimeout(cls._SEND_TIMEOUT)
                    return sock
                except Exception:
                    try:
                        sock.close()
                    except Exception:
                        pass
            return cls._create_socket(host, port, ssl_enabled)

    @classmethod
    def _return_to_pool(cls, host: str, port: int, ssl_enabled: bool, sock: socket.socket):
        """Return a socket to the pool if it seems healthy."""
        key = cls._pool_key(host, port, ssl_enabled)
        with cls._pool_lock:
            pool = cls._pools.setdefault(key, [])
            if len(pool) < cls._POOL_SIZE:
                pool.append(sock)
            else:
                try:
                    sock.close()
                except Exception:
                    pass

    @classmethod
    def send(cls, host: str, port: int, ssl_enabled: bool, data: bytes) -> Tuple[bool, float]:
        """
        Send data, receive partial response, return (success, latency_ms).
        Uses connection pooling for speed.
        """
        start = time.perf_counter()
        sock = cls._get_from_pool(host, port, ssl_enabled)
        if not sock:
            return False, 0.0

        try:
            sock.sendall(data)
            # Try to read a bit — helps complete the TCP exchange properly
            try:
                sock.settimeout(cls._RECV_TIMEOUT)
                sock.recv(1024)
            except socket.timeout:
                pass
            except Exception:
                pass

            latency = (time.perf_counter() - start) * 1000  # ms

            # Return healthy socket to pool
            cls._return_to_pool(host, port, ssl_enabled, sock)
            return True, latency

        except (socket.timeout, ConnectionError, BrokenPipeError, OSError) as e:
            try:
                sock.close()
            except Exception:
                pass
            return False, (time.perf_counter() - start) * 1000

    @classmethod
    def cleanup(cls):
        """Close all pooled sockets."""
        with cls._pool_lock:
            for key, pool in cls._pools.items():
                for sock in pool:
                    try:
                        sock.close()
                    except Exception:
                        pass
            cls._pools.clear()

