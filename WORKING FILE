@dataclass
class Target:
    """Parsed target information."""
    host: str
    port: int
    path: str
    ssl: bool
    raw: str

    @classmethod
    def parse(cls, url: str) -> Optional['Target']:
        """Parse a URL string into a validated Target object."""
        if not url:
            return None
        if not url.startswith(("http://", "https://")):
            url = "http://" + url
        try:
            parsed = urlparse(url)
            host = parsed.hostname
            if not host:
                return None
            ssl = parsed.scheme == "https"
            port = parsed.port or (443 if ssl else 80)
            path = parsed.path or "/"
            if parsed.query:
                path += "?" + parsed.query
            return cls(host=host, port=port, path=path, ssl=ssl, raw=parsed.geturl())
        except Exception:
            return None

