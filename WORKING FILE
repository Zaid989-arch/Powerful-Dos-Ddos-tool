# PROGRESS BAR
# ──────────────────────────────────────────
class ProgressBar:
    """Simple animated progress bar for Termux."""

    @staticmethod
    def render(current: int, total: int, width: int = 30) -> str:
        """Return a progress bar string."""
        if total <= 0:
            return ""
        pct = min(100, (current / total) * 100)
        filled = int((pct / 100) * width)
        bar = "█" * filled + "░" * (width - filled)
        return f"[{C(bar)}] {GB(f'{pct:.0f}%')}"

